# Copy this file to .env and fill in real values (or set these as env vars in the Hostinger panel).

# Required: secret key clients must send as header `x-api-key` or query param `?key=`
API_KEY=change-me-to-a-long-random-secret

# Port the server listens on (Hostinger usually injects this automatically)
PORT=3000

# Prepended to every phone number passed to /send and /sendMedia (e.g. "2" for Egypt)
COUNTRY_CODE=2

# Optional: root folder holding one subfolder per connected number/session
# (defaults to ./.sessions). Each session's auth files live in <root>/<sender>.
# SESSIONS_ROOT=./.sessions

# Optional: max number of concurrent WhatsApp sessions this process may run
# (defaults to 5). Keep this modest on shared hosting.
# MAX_SESSIONS=5
